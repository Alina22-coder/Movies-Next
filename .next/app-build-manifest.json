{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/page.css",
      "static/chunks/app/page.js"
    ],
    "/(public)/movies/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(public)/movies/layout.js"
    ],
    "/(public)/movies/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(public)/movies/page.css",
      "static/chunks/app/(public)/movies/page.js"
    ],
    "/(public)/movie/[id]/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(public)/movie/[id]/layout.js"
    ],
    "/(public)/movie/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/(public)/movie/[id]/page.css",
      "static/chunks/app/(public)/movie/[id]/page.js"
    ]
  }
}